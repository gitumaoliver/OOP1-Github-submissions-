//Mobile data purchases using switch case nstead of the if 
#include <iostream>
using namespace std;

int main() {
    int choice;

    cout << "1. Daily Bundle - 50\n";
    cout << "2. Weekly Bundle - 200\n";
    cout << "3. Monthly Bundle - 800\n";
    cout << "Choose option: ";
    cin >> choice;

    switch(choice) {
        case 1:
            cout << "Daily Bundle selected" << endl;
            break;
        case 2:
            cout << "Weekly Bundle selected" << endl;
            break;
        case 3:
            cout << "Monthly Bundle selected" << endl;
            break;
        default:
            cout << "Invalid choice" << endl;
    }

    return 0;
}
