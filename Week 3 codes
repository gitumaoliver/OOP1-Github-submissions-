//Water bill claculator 
#include <iostream>
using namespace std;

int main() {
    int units;
    float bill = 0;

    cout << "Enter water units used: ";
    cin >> units;

    if (units <= 30) {
        bill = units * 10;
    } else if (units <= 50) {
        bill = (30 * 10) + (units - 30) * 15;
    } else {
        bill = (30 * 10) + (20 * 15) + (units - 50) * 20;
    }

    cout << "Total bill = " << bill << endl;

    return 0;
}

