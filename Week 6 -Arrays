//1D array 
#include <iostream>
#include <vector>
#include <iomanip>
using namespace std;

int main() {
    vector<double> revenue(7);
    for (int i = 0; i < 7; ++i) {
        if (!(cin >> revenue[i])) return 0;
    }
    double total = 0;
    for (double r : revenue) total += r;
    cout.setf(ios::fixed); cout.precision(2);
    cout << "Total weekly revenue: " << total << '\n';
    cout << "Average daily revenue: " << (total / 7.0) << '\n';
    return 0;
}
//2D array 
#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

int main() {
    const int floors = 5, rooms = 10;
    int occupancy[floors][rooms];
    srand((unsigned)time(nullptr));
    for (int f = 0; f < floors; ++f)
        for (int r = 0; r < rooms; ++r)
            occupancy[f][r] = rand() % 2; // 1 occupied, 0 vacant

    for (int f = 0; f < floors; ++f) {
        int occ = 0, vac = 0;
        for (int r = 0; r < rooms; ++r) (occupancy[f][r] ? ++occ : ++vac);
        cout << "Floor " << (f + 1) << ": Occupied = " << occ << ", Vacant = " << vac << '\n';
    }
    return 0;
}

//3D array 
#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

int main() {
    const int branches = 3, floors = 5, rooms = 10;
    int chain[branches][floors][rooms];
    srand((unsigned)time(nullptr));
    for (int b = 0; b < branches; ++b)
        for (int f = 0; f < floors; ++f)
            for (int r = 0; r < rooms; ++r)
                chain[b][f][r] = rand() % 2;

    int totalOccupied = 0;
    for (int b = 0; b < branches; ++b) {
        int branchOcc = 0;
        for (int f = 0; f < floors; ++f)
            for (int r = 0; r < rooms; ++r)
                if (chain[b][f][r]) ++branchOcc;
        totalOccupied += branchOcc;
        cout << "Branch " << (b + 1) << " occupied rooms: " << branchOcc << '\n';
    }
    cout << "Total occupied rooms across all branches: " << totalOccupied << '\n';
    return 0;
}
